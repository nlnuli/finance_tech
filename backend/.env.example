APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=finance_tech
QDRANT_URL=https://your-cluster.qdrant.tech:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=finance_tech_chunks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_ENABLED=true
MEMORY_DIR=/Users/yewen/finance_helpers/finance_tech/backend/memory
MEMORY_DEFAULT_USER_ID=default
MEMORY_AUTO_TRIGGER_MESSAGE_COUNT=10
MEMORY_INDEX_MAX_LINES=200
MEMORY_INDEX_MAX_BYTES=25600
