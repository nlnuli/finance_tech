{
  "servers": [
    {
      "name": "tavily",
      "transport": "http",
      "enabled": true,
      "url": "https://mcp.tavily.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${TAVILY_API_KEY}"
      },
      "timeout_seconds": 60,
      "sse_read_timeout_seconds": 300,
      "retry_attempts": 3
    }
  ]
}
